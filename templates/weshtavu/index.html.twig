{% extends 'weshtavu/base.html.twig' %}

{% block title %}Hello HomeController!{% endblock %}

{% block body %}
    <div class="row row-cols-2 row-cols-xl-3 g-4" data-masonry='{"percentPosition": true }'>
        <section>
            {% for event in events %}
            <article>
                <twig:Article :event="event" withCloseButton />
            </article>
            {% endfor %}
            <article>
                <div class="video-card card mb-3">
                    <div class="row g-0">
                        <div class="col-md-4">
                            <img src="https://img.youtube.com/vi/O-HdzUU5bhE/0.jpg" class="img-fluid rounded-start"
                                 alt="..." style="height:100%;">
                        </div>
                        <div class="col-md-8">
                            <div class="card-body">
                                <h3 class="card-title">Les Sénégalaises</h3>
                                <p class="card-text">SanSeverino</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="video-card card mb-3">
                    <div class="row g-0">
                        <div class="col-md-4 order-md-last order-first">
                            <img src="https://img.youtube.com/vi/O-HdzUU5bhE/0.jpg" class="img-fluid rounded-end"
                                 alt="..." style="height:100%;">
                        </div>
                        <div class="col-md-8">
                            <div class="card-body" style="text-align:right">
                                <h3 class="card-title">Les Sénégalaises</h3>
                                <p class="card-text">SanSeverino</p>
                            </div>
                        </div>

                    </div>
                </div>
                <div class="video-card card mb-3">
                    <div class="row g-0">
                        <div class="col-md-4">
                            <img src="https://img.youtube.com/vi/O-HdzUU5bhE/0.jpg" class="img-fluid rounded-start"
                                 alt="..." style="height:100%;">
                        </div>
                        <div class="col-md-8">
                            <div class="card-body">
                                <h3 class="card-title">Les Sénégalaises</h3>
                                <p class="card-text">SanSeverino</p>
                            </div>
                        </div>
                    </div>
                </div>
            </article>

        </section>
        <section style="background-color: rgba(255,255,255,0.7)">
            <article>
                <span class="event-type">AU CINOCHE</span>
                <h2>Les films de la semaine</h2>
                <div class="subtitle d-flex justify-content-between">
                    <span class="author">Kevin Smith</span>
                    <span>&#9733; &#9733; &#9733;</span>
                    <span class="year">1995</span>
                </div>
                <div>
                    <div class="row g-0">
                        {% for film in films %}
                            <div class="col-12">
                                <img src="{{ asset('uploads/cinema/' ~ film.picture) }}" class="img-fluid rounded-top"
                                     alt="..." style="height:100%;">
                            </div>
                            <div class="col-12">
                                <div class="card-body" style="text-align:center;">
                                    <h3 class="card-title">{{ film.name }}</h3>
                                    <p class="card-text">film</p>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </article>
        </section>
        <section>
            <article class="">
                <span class="event-type">A LA RADIO</span>
                <h2>La playlist de la semaine</h2>
                <div class="subtitle d-flex justify-content-between">
                    <span class="author">Kevin Smith</span>
                    <span>&#9733; &#9733; &#9733;</span>
                    <span class="year">1995</span>
                </div>
                <div class="video-card card m-5">
                    <div class="row g-0">
                        <div class="col-12">
