                                 alt="..." style="height:100%;">
                        </div>
                        <div class="col-12">
                            <div class="card-body" style="text-align:center;">
                                <h3 class="card-title">Travolta vs Rabbi Jacob</h3>
                                <p class="card-text">Xtrem</p>
                            </div>
                        </div>
                    </div>
                </div>
                <img src="{{ asset('resources/villemot/[Clio Team] Villemot 1956 Orangina.jpg') }}" width="100%"
                         style="border: 10px solid black;">
                <div class="video-card card m-5">
                    <div class="row g-0">
                        <div class="col-12">
                            <img src="https://img.youtube.com/vi/2Z-2Zonbano/0.jpg" class="img-fluid rounded-top"
                                 alt="..." style="height:100%;">
                        </div>
                        <div class="col-12">
                            <div class="card-body" style="text-align:center;">
                                <h3 class="card-title">Travolta vs Rabbi Jacob</h3>
                                <p class="card-text">Xtrem</p>
                            </div>
                        </div>
                    </div>
                </div>
                <p>
                    Les menaces de Donald Trump contre le Groenland et l’Europe montrent comment le président américain
