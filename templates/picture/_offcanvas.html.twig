<div class="offcanvas offcanvas-start" data-bs-scroll="true" data-bs-backdrop="false" tabindex="-1" id="offcanvasScrolling" aria-labelledby="offcanvasScrollingLabel">
    <div class="offcanvas-header">
        <h5 class="offcanvas-title" id="offcanvasScrollingLabel">{{ title }}</h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <div class="offcanvas-body" data-controller="picture">
        {% set form = search_form() %}
        {{ form_start(form) }}
        <div><div class="input-group input-group-sm">
            {{ form_widget(form.painter) }}
            {{ form_widget(form.submit) }}
            </div>
        </div>
        {{ form_end(form) }}
        <br>
        <div class="row justify-content-center">
            <a href="{{ path('picture_random') }}" class="btn btn-light">Aller au hasard</a>
            <br><br>
            {% if is_granted('ROLE_ADMIN') and 'picture_artist' == app.current_route %}
                <a href="#" class="btn btn-light" data-action="picture#toggleForm">Editer</a>
            {% endif %}
        </div>
    </div>
</div>
