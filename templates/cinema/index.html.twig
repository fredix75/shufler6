{% extends 'base.html.twig' %}

{% block title %}Hello CinemaController!{% endblock %}

{% block body %}

    <div class="container-fluid" data-controller="cinema">
        <div class="row">
            <div class="col-3">
                <img src="{{ asset('uploads/cinema/' ~ film.picture) }}" width="100%">
            </div>
            <div class="col-3">
                <img src="{{ asset('https://image.tmdb.org/t/p/w1280' ~ film.posterPath) }}" width="100%">
            </div>
            <div class="col-6 justify-content-around">
                <h2>{{ film.name }}</h2>
                <h3>{{ film.year }}</h3>
                <a href="{{ path('cinema_index', {check: true}) }}" class="btn btn-success btn-lg">OK</a>
                <a href="#" class="btn btn-info btn-lg" data-action="cinema#toggleForm">Form</a>
                <a href="{{ path('cinema_index', {noRef: true}) }}" class="btn btn-danger btn-lg" data-action="">NOPE</a>
                <p style="font-size:120%">{{ film.overview }}</p>
                {% for genre in film.genresLabels %}
                    <span class="badge bg-dark">{{ genre }}</span>
                {% endfor %}
                <div class="">
                    {{ form(form) }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
